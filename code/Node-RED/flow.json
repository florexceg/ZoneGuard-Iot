    {
        "id": "cf56ddf190cc3d5d",
        "type": "function",
        "z": "20a5a4c608733a68",
        "name": "function 1",
        "func": "let history = flow.get(\"history\") || [];\n\nlet icon = \"🟢\";\n\nif (msg.payload.zone === \"CORRIDOR\") {\n    icon = \"🟡\";\n}\nelse if (msg.payload.zone === \"EXIT\") {\n    icon = \"🔴\";\n}\n\nlet event = {\n    icon: icon,\n    time: msg.payload.timestamp,\n    message: msg.payload.message\n};\n\nhistory.unshift(event);\n\nif (history.length > 10) {\n    history.pop();\n}\n\nflow.set(\"history\", history);\n\nmsg.payload = history;\n\nreturn msg;",
        "outputs": 1,
        "timeout": 0,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 540,
        "y": 500,
        "wires": [
            [
                "0e434c0ec41d8f22"
            ]
        ]
    },
    {
        "id": "d6f47ecf4c70945c",
        "type": "ui-template",
        "z": "20a5a4c608733a68",
