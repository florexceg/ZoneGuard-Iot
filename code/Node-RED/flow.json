        "page": "",
        "ui": "",
        "name": "🚨 Emergency Alert",
        "order": 1,
        "width": "6",
        "height": "2",
        "head": "",
        "format": "<div\n:style=\"{\nbackground:\nmsg.payload.status=='SAFE'\n? '#2E7D32'\n: msg.payload.status=='WARNING'\n? '#F9A825'\n: '#C62828',\n\ncolor:'white',\npadding:'18px',\nborderRadius:'12px',\ntextAlign:'center',\nfontSize:'22px',\nfontWeight:'bold'\n}\">\n\n<div v-if=\"msg.payload.status=='SAFE'\">\n🟢 SAFE\n<br><br>\nPatient is safely inside the restricted area.\n</div>\n\n<div v-else-if=\"msg.payload.status=='WARNING'\">\n🟡 WARNING\n<br><br>\nPatient is currently in the corridor.\n</div>\n\n<div v-else>\n🚨 EMERGENCY\n<br><br>\nPatient has reached the EXIT!\n<br>\nImmediate Staff Attention Required\n</div>\n\n</div>",
