    {
        "id": "0e434c0ec41d8f22",
        "type": "ui-template",
        "z": "20a5a4c608733a68",
        "group": "2b5f6be8e673a411",
        "page": "",
        "ui": "",
        "name": " Activity Log",
        "order": 1,
        "width": "6",
        "height": "6",
        "head": "",
        "format": "<div style=\"padding:10px;font-family:Arial\">\n\n    <div v-for=\"item in msg.payload\"\n         style=\"\n            background:white;\n            border-left:6px solid #1976D2;\n            padding:12px;\n            margin-bottom:12px;\n            border-radius:8px;\n            box-shadow:0 2px 5px rgba(0,0,0,.15);\n         \">\n\n        <div style=\"font-size:20px;\">\n            {{item.icon}}\n        </div>\n\n        <div style=\"font-size:13px;color:gray;\">\n            {{item.time}}\n        </div>\n\n        <div style=\"font-weight:bold;font-size:16px;margin-top:6px;\">\n            {{item.message}}\n        </div>\n\n    </div>\n\n</div>",
